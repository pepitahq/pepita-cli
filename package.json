{
  "name": "@pepitahq/cli",
  "version": "0.4.1",
  "description": "Command-line for pepita sites — create, pull, apply, save, publish, delete.",
  "license": "MIT",
  "author": "Zoltan Gobolos <zgobolos@barelynotable.com>",
  "type": "module",
  "bin": {
    "pepita": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pepitahq/pepita-cli.git"
  },
  "homepage": "https://github.com/pepitahq/pepita-cli#readme",
  "bugs": {
    "url": "https://github.com/pepitahq/pepita-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm build",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@pepitahq/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
